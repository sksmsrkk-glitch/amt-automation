# ===================================
# n8n Partner Reservation Automation
# Environment Configuration Template
# ===================================

# -------------------------
# Email Configuration
# -------------------------

# Partner email domain for filtering incoming reservation requests
# Example: partner.com, reservations.example.com
PARTNER_EMAIL_DOMAIN=partner.com

# -------------------------
# File Paths
# -------------------------

# Path to hotel master Excel file containing hotel mappings
# Sheet name must be "Hotels" with columns: hotel_name_en, hotel_code, product_code
HOTEL_MASTER_PATH=/data/hotels/hotel_master.xlsx

# Path to reservation template Excel file
# Sheet name must be "Reservations" with headers in row 1
RESERVATION_TEMPLATE_PATH=/data/templates/reservation_template.xlsx

# Output directory for generated Excel files and screenshots
# Must be writable by n8n process
OUTPUT_DIR=/data/output

# -------------------------
# Admin Portal Credentials
# -------------------------

# Admin portal username
ADMIN_USER=your-admin-username

# Admin portal password
ADMIN_PASS=your-admin-password

# -------------------------
# Matching Configuration
# -------------------------

# Hotel name fuzzy matching threshold (0.0 - 1.0)
# 1.0 = exact match required
# 0.85 = recommended default (allows minor typos)
# 0.75 = lenient (more false positives)
HOTEL_MATCH_THRESHOLD=0.85

# -------------------------
# Slack Configuration
# -------------------------

# Slack channel for notifications (optional)
# Include the # symbol
SLACK_CHANNEL=#reservations

# -------------------------
# Playwright Configuration
# -------------------------

# Run Playwright in headless mode
# Set to 'false' for debugging/visual verification
PLAYWRIGHT_HEADLESS=true

# -------------------------
# n8n Configuration (optional)
# -------------------------

# n8n webhook URL (if using external triggers)
# N8N_WEBHOOK_URL=https://your-n8n.com/webhook/

# n8n encryption key (for securing credentials)
# N8N_ENCRYPTION_KEY=your-encryption-key

# n8n timezone
# N8N_TIMEZONE=Asia/Seoul

# -------------------------
# Advanced Settings
# -------------------------

# Email poll interval in seconds (default: 300 = 5 minutes)
EMAIL_POLL_INTERVAL=300

# Maximum retry attempts for failed uploads
MAX_UPLOAD_RETRIES=2

# Retry delay in milliseconds
RETRY_DELAY_MS=5000

# PDF download timeout in milliseconds
PDF_DOWNLOAD_TIMEOUT=60000

# Playwright page timeout in milliseconds
PLAYWRIGHT_PAGE_TIMEOUT=30000

# Enable debug logging (true/false)
DEBUG_MODE=false
